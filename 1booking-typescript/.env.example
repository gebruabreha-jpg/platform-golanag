# ==========================================
# 1Booking Typescript - Backend Service
# ==========================================

# Node
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/1booking_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=super_secret_jwt_key_change_in_production_min_32_chars
JWT_REFRESH_SECRET=super_secret_refresh_key_change_in_production_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# Logging
LOG_LEVEL=info

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# S3 / Object Storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=1booking-media

# AI Service
AI_SERVICE_URL=http://localhost:8000
OPENAI_API_KEY=sk-xxx

# App
APP_URL=http://localhost:3000
