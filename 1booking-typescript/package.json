{
  "name": "1booking-typescript",
  "version": "1.0.0",
  "description": "Booking platform (flights, shipping, housing, services) - TypeScript/Node.js backend",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs --clean",
    "build:watch": "tsup src/index.ts --format cjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" --cache",
    "lint:fix": "eslint \"src/**/*.ts\" --cache --fix",
    "format": "prettier --write \"src/**/*.{*ts,json,md}\"",
    "test": "jest --coverage --passWithNoTests",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config tests/jest.e2e.config.js",
    "db:migrate": "node -e \"const {execSync}=require('child_process'); execSync('psql $DATABASE_URL -f src/database/migrations/*.sql', {stdio:'inherit'})\"",
    "db:seed": "node -e \"const {execSync}=require('child_process'); execSync('psql $DATABASE_URL -f src/database/seeds/*.sql', {stdio:'inherit'})\"",
    "db:studio": "npx drizzle-kit studio",
    "db:generate": "npx drizzle-kit generate",
    "prepare": "husky install"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.30.10",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "pino": "^8.19.0",
    "pino-http": "^8.5.1",
    "pusher": "^5.2.0",
    "redis": "^4.6.12",
    "slugify": "^1.6.6",
    "stripe": "^14.25.0",
    "uuid": "^9.0.1",
    "winston": "^3.13.1",
    "winston-transport": "^4.7.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "eslint-plugin-security": "^2.1.1",
    "jest": "^29.7.0",
    "pre-commit": "^1.2.2",
    "prettier": "^3.2.4",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
