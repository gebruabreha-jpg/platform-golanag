# ConnectMe Environment Configuration
# Copy this file to .env and update values

# ==================== BACKEND ====================
# Server
ENVIRONMENT=development
SERVER_ADDR=:8080

# Database
DATABASE_URL=postgresql://connectme_user:connectme_pass_2024@localhost:5432/connectme?sslmode=disable
MIGRATIONS_URL=file://migrations

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# NATS
NATS_URL=nats://localhost:4222
NATS_CLUSTER_ID=connectme

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters
JWT_EXPIRY=24h
REFRESH_SECRET=your-refresh-token-secret

# Stripe (Payment Processing)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# AWS S3 (or MinIO for local)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET=connectme-uploads
S3_ENDPOINT=http://localhost:9000  # MinIO local endpoint

# AI Service
AI_SERVICE_URL=http://localhost:8000
OPENAI_API_KEY=sk-your-openai-key  # Optional, for enhanced features

# Mapbox (Maps)
MAPBOX_TOKEN=pk.your_mapbox_token

# ==================== AI SERVICE ====================
DATABASE_URL=postgresql://connectme_user:connectme_pass_2024@localhost:5432/connectme
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

MODEL_PATH=./models
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
DEVICE=cpu  # or "cuda" if GPU available

BACKEND_URL=http://localhost:8080
HUGGINGFACE_TOKEN=hf_your_token  # Optional

# ==================== FRONTEND ====================
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_AI_URL=http://localhost:8000
MAPBOX_TOKEN=pk.your_mapbox_token
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key

# NextAuth (if using auth.js)
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Email Service (SendGrid, AWS SES, etc.)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_key

# ==================== PRODUCTION / CLOUD ====================
# Uncomment and modify for production deployment

# Production Database
# DATABASE_URL=postgresql://user:password@db.connectme.io:5432/connectme_prod

# Production Redis (Redis Cloud)
# REDIS_ADDR=redis-12345.connectme.io:12345
# REDIS_PASSWORD=your_redis_password

# Production NATS (NATS Cloud)
# NATS_URL=nats://connectme-nats.connectme.io:4222

# Production S3 (AWS)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# S3_BUCKET=connectme-prod-uploads

# VAPID for web push notifications
# VAPID_PUBLIC_KEY=your_vapid_public_key
# VAPID_PRIVATE_KEY=your_vapid_private_key

# Sentry (error monitoring)
# SENTRY_DSN=https://your_sentry_dsn

# Logging
LOG_LEVEL=info  # debug, info, warn, error

# ==================== LOCAL DEVELOPMENT ====================
# These are set automatically by docker-compose
