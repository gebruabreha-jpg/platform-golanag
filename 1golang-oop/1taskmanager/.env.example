# Copy to .env and fill in values. Never commit the real .env.
# If DATABASE_URL is empty, the API uses an in-memory store (data lost on restart).

# HTTP server port the container listens on
PORT=8080

# Set this to persist tasks in PostgreSQL (e.g. the DB your Terraform creates).
# Format: postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=

# "prod" (default) = JSON logs; "dev"/"local" = text logs
APP_ENV=prod
