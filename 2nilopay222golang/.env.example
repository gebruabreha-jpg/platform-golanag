# Server Configuration
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/nilo_commerce

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Wise Business API
WISE_API_TOKEN=your_wise_api_token
WISE_API_PROFILE_ID=your_wise_profile_id
WISE_API_CURRENCY=USD
WISE_LOCAL_CURRENCY=ETB

# Application Settings
DEFAULT_FEE_PERCENTAGE=2.5
FX_SPREAD_BPS=50
MINIMUM_TRANSACTION_AMOUNT=10
MAXIMUM_TRANSACTION_AMOUNT=10000

# Ethiopian Banks (supported)
SUPPORTED_BANKS=CBE,Awash,Dashen,Abyssinia,Coop,Enigma,Bofed
DEFAULT_BANK=CBE

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Redis (optional for caching)
REDIS_URL=redis://localhost:6379

# Email Service (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
