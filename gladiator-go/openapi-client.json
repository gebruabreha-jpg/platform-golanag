        }
      }
    },
    "/certificates/{task_id}": {
      "get": {
        "tags": ["Certificates"],
        "summary": "Get certificate task details",
        "description": "Returns details of a specific certificate retrieval task",
        "operationId": "getCertificateTask",
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "description": "Certificate task UUID",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Certificate task details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CertificateTask"
                }
              }
            }
          },
          "404": {
            "description": "Certificate task not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/openapi.json": {
      "get": {
        "summary": "Get OpenAPI specification",
        "description": "Returns the OpenAPI specification for this API",
        "responses": {
          "200": {
            "description": "OpenAPI specification"
          }
        }
      }
    },
    "/docs": {
      "get": {
        "summary": "API documentation",
        "description": "Interactive API documentation (Swagger UI)",
        "responses": {
          "200": {
            "description": "HTML documentation page"
          }
        }
      }
    }
  },
